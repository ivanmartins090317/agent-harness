# ─── Anthropic ────────────────────────────────────────────────────────────────
# Obrigatória quando AGENT_PLAN_PROVIDER ou AGENT_EXEC_PROVIDER = "anthropic"
ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenRouter ───────────────────────────────────────────────────────────────
# Obrigatória quando AGENT_PLAN_PROVIDER ou AGENT_EXEC_PROVIDER = "openrouter"
# Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ─── Providers por fase ───────────────────────────────────────────────────────
# Valores aceitos: "anthropic" | "openrouter"
# Dica: use "anthropic" no plan (mais inteligente) e "openrouter" no exec (mais barato)
AGENT_PLAN_PROVIDER=anthropic
AGENT_EXEC_PROVIDER=anthropic

# ─── Modelos ──────────────────────────────────────────────────────────────────
# Modelo para planejamento (fase plan, step 1)
AGENT_PLAN_MODEL=claude-opus-4-20250514

# Modelo para execução (demais steps)
# Exemplos de modelos gratuitos no OpenRouter:
#   meta-llama/llama-3.3-70b-instruct:free
#   google/gemma-3-27b-it:free
#   qwen/qwen3-235b-a22b:free
AGENT_EXEC_MODEL=claude-opus-4-20250514

# ─── Loop ─────────────────────────────────────────────────────────────────────
# Número máximo de iterações do loop do agente
AGENT_MAX_STEPS=30

# Timeout (ms) para comandos de terminal
AGENT_TERMINAL_TIMEOUT_MS=120000
