# Chave da API Anthropic (obrigatória para executar tarefas reais)
ANTHROPIC_API_KEY=sk-ant-...

# Modelo usado para planejamento (Tech Design Doc, decisões complexas)
AGENT_PLAN_MODEL=claude-opus-4-20250514

# Modelo usado para execução de passos
AGENT_EXEC_MODEL=claude-opus-4-20250514

# Número máximo de iterações do loop do agente
AGENT_MAX_STEPS=30

# Timeout (ms) para comandos de terminal
AGENT_TERMINAL_TIMEOUT_MS=120000
